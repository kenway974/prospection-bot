# === GOOGLE PLACES API ===
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# === CRITÈRES DE RECHERCHE ===
# Mots-clés séparés par des virgules
SEARCH_KEYWORDS=restaurant,boulangerie,agence immobilière,garage automobile,cabinet dentaire
# Ville / zone géographique
SEARCH_LOCATION=Lyon, France
# Rayon de recherche en mètres (max 50000)
SEARCH_RADIUS=10000
# Nombre max de prospects à traiter par mot-clé
MAX_RESULTS_PER_KEYWORD=5

# === CONFIGURATION PROSPECTEUR ===
# Votre prénom (pour la signature des mails)
YOUR_NAME=Kenny
# Votre titre
YOUR_TITLE=Développeur Web Freelance
# Votre email de contact
YOUR_EMAIL=kenny@example.com
# Votre site web (optionnel)
YOUR_WEBSITE=https://kennydev.fr
